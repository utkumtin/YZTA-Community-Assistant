# ==============================================================================
# Akademi Topluluk Asistanı — ortam değişkenleri
# Kaynak: packages/settings.py (Settings)
# Proje kökünde .env dosyası oluşturup bu dosyayı kopyalayın ve değerleri doldurun.
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL (postgresql+asyncpg — packages/database/manager.py)
# Şifrede özel karakter varsa düz yazın; URL oluşturulurken kaçış uygulanır.
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=slack_community_agent

# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
# DB_POOL_PRE_PING=true
# DB_POOL_RECYCLE=1800

# ------------------------------------------------------------------------------
# Slack (slack_bolt + Socket Mode — packages/slack/client.py)
# ------------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-senin-bot-token-buraya
SLACK_APP_TOKEN=xapp-senin-app-token-buraya
SLACK_USER_TOKEN=xoxp-senin-user-token-buraya

# Virgülle ayrılmış Slack kullanıcı ID'leri (workspace owner)
SLACK_WORKSPACE_OWNER_ID=U0123456789
# Admin Slack kullanıcı ID'leri (virgülle ayırın: U123,U456)
SLACK_ADMIN_SLACK_ID=U0123456789
# Admin bildirim kanalı; challenge kanalı (kanal ID: C...)
SLACK_ADMIN_CHANNEL=C0123456789
SLACK_CHALLENGE_CHANNEL=C0123456789

# ------------------------------------------------------------------------------
# Monitör aralıkları (saniye) — isteğe bağlı
# ------------------------------------------------------------------------------
# MONITOR_CHALLENGE_INTERVAL=60
# MONITOR_DEADLINE_INTERVAL=300
# MONITOR_EVALUATION_INTERVAL=600

# ------------------------------------------------------------------------------
# Challenge / değerlendirme limitleri — isteğe bağlı
# ------------------------------------------------------------------------------
# CHALLENGE_MIN_PARTICIPANTS=2
# CHALLENGE_MAX_PARTICIPANTS=5
# EVALUATION_MAX_WAIT_HOURS=24
# EVALUATION_JURY_COUNT=2

# ------------------------------------------------------------------------------
# SMTP (isteğe bağlı — ikisini birden doldurun veya ikisini de boş bırakın)
# ------------------------------------------------------------------------------
# SMTP_EMAIL=
# SMTP_PASSWORD=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_TIMEOUT=30

# ------------------------------------------------------------------------------
# Event Service
# ------------------------------------------------------------------------------
# EVENT_CHANNEL=C0123456789
# EVENT_REMINDER_ENABLED=true
# EVENT_APPROVAL_TIMEOUT_HOURS=72
# EVENT_TIMEZONE=Europe/Istanbul
# EVENT_MORNING_REMINDER_HOUR=8
